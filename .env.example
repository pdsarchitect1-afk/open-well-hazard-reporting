# ---- MongoDB Atlas (free M0) ----
# Create a free cluster at https://www.mongodb.com/cloud/atlas
# In "Network Access" allow 0.0.0.0/0 so Vercel serverless can connect.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/openwell?retryWrites=true&w=majority"

# ---- Cloudinary (free) — used for SIGNED direct browser photo upload ----
# Find these in your Cloudinary dashboard (Settings > API Keys).
# The browser asks our /api/cloudinary-sign route for a signature, so the
# secret stays server-side and anonymous users can't upload without approval.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
NEXT_PUBLIC_CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"   # SERVER ONLY — never prefix with NEXT_PUBLIC

# ---- Admin dashboard ----
# The single shared password that unlocks /admin
ADMIN_PASSWORD="change-this-admin-password"
# A long random string used to sign the admin session cookie
ADMIN_SESSION_SECRET="change-this-to-a-long-random-string"

# ---- App ----
# Public base URL (used for QR code links). Optional in dev.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
